Newton <- function(x1 = 0, x2 = 0, tol = 1e-8, max_iter = 100) {
# Objective function
f <- function(x) {
5*x[1]^2 + 6*x[1]*x[2] + 4*x[2]^2 + 3*x[1] + 4*x[2] + 7
}
# Gradient of the objective function
gradient <- function(x) {
g1 <- 10*x[1] + 6*x[2] + 3
g2 <- 6*x[1] + 8*x[2] + 4
return(c(g1, g2))
}
# Hessian matrix (constant for this quadratic function)
hessian <- matrix(c(10, 6, 6, 8), nrow = 2, byrow = TRUE)
# Starting point
x <- c(x1, x2)
# Store iteration history
history <- data.frame(
iter = 0,
x1 = x[1],
x2 = x[2],
f_value = f(x),
grad_norm = sqrt(sum(gradient(x)^2))
)
cat("Newton-Raphson Method for Optimization\n")
cat("Starting point: (", x[1], ", ", x[2], ")\n\n", sep = "")
# Newton-Raphson iterations
for (iter in 1:max_iter) {
# Compute gradient at current point
grad <- gradient(x)
grad_norm <- sqrt(sum(grad^2))
# Check convergence
if (grad_norm < tol) {
cat("Converged in", iter - 1, "iterations\n\n")
break
}
# Newton step: x_new = x - H^(-1) * gradient
H_inv <- solve(hessian)
x_new <- x - H_inv %*% grad
# Update
x <- as.vector(x_new)
# Store history
history <- rbind(history, data.frame(
iter = iter,
x1 = x[1],
x2 = x[2],
f_value = f(x),
grad_norm = grad_norm
))
if (iter == max_iter) {
cat("Maximum iterations reached\n\n")
}
}
print(history, row.names = FALSE)
# Return results
return(invisible(list(
x_optimal = x,
f_optimal = f(x),
gradient = gradient(x),
iterations = nrow(history) - 1,
history = history
)))
}
result1 <- Newton()
result1 <- Newton()
result2 <- Newton(3, 2)
Newton <- function(x1 = 0, x2 = 0, tol = 1e-10, maxit = 50, verbose = TRUE) {
# Objective: f(x1,x2) = 5 x1^2 + 6 x1 x2 + 4 x2^2 + 3 x1 + 4 x2 + 7
f <- function(x) {
x1 <- x[1]; x2 <- x[2]
5*x1^2 + 6*x1*x2 + 4*x2^2 + 3*x1 + 4*x2 + 7
}
# Gradient: ∇f = [10 x1 + 6 x2 + 3, 6 x1 + 8 x2 + 4]
grad <- function(x) {
c(10*x[1] + 6*x[2] + 3,
6*x[1] + 8*x[2] + 4)
}
# Constant Hessian: H = [[10,6],[6,8]]
H <- matrix(c(10, 6, 6, 8), nrow = 2, byrow = TRUE)
x <- c(x1, x2)
for (it in 1:maxit) {
g <- grad(x)
step <- solve(H, g)   # Newton step: H s = g
x_new <- x - step
if (verbose) {
cat(sprintf("Iter %d: x = (%.6f, %.6f), f = %.12f, ||step|| = %.3e\n",
it, x_new[1], x_new[2], f(x_new), sqrt(sum(step^2))))
}
if (sqrt(sum(step^2)) < tol) {
x <- x_new
break
}
x <- x_new
}
list(
par = x,
value = f(x),
grad = grad(x),
hessian = H,
iter = it,
converged = (sqrt(sum(step^2)) < tol)
)
}
Newton()        # starts at (0, 0)
Newton(3, 2)    # starts at (3, 2)
Newton()        # starts at (0, 0)
Newton(3, 2)    # starts at (3, 2)
Newton <- function(x1 = 0, x2 = 0, tol = 1e-12, maxit = 20, verbose = TRUE) {
f <- function(x) {
5*x[1]^2 + 6*x[1]*x[2] + 4*x[2]^2 + 3*x[1] + 4*x[2] + 7
}
grad <- function(x) {
c(10*x[1] + 6*x[2] + 3,
6*x[1] + 8*x[2] + 4)
}
H <- matrix(c(10, 6, 6, 8), nrow = 2, byrow = TRUE)
x <- c(x1, x2)
for (it in 1:maxit) {
g <- grad(x)
step <- solve(H, g)     # H %*% step = grad
x_new <- x - step       # Newton 更新（注意有负号）
if (verbose) {
cat(sprintf("iter %d: x=(%.12g, %.12g), f=%.12g, ||step||=%.3e\n",
it, x_new[1], x_new[2], f(x_new), sqrt(sum(step^2))))
}
if (sqrt(sum(step^2)) < tol) {
x <- x_new
break
}
x <- x_new
}
# 为了打印好看，做个四舍五入
x_rounded <- round(x, 12)
list(par = x_rounded, value = f(x), grad = grad(x), hessian = H, iter = it)
}
Newton()$par        # 期望 c(0, -0.5)
Newton(3, 2)$par    # 同样返回 c(0, -0.5)
Newton <- function(x1 = 0, x2 = 0, tol = 1e-12, maxit = 20, verbose = TRUE) {
f <- function(x) {
5*x[1]^2 + 6*x[1]*x[2] + 4*x[2]^2 + 3*x[1] + 4*x[2] + 7
}
grad <- function(x) {
c(10*x[1] + 6*x[2] + 3,
6*x[1] + 8*x[2] + 4)
}
H <- matrix(c(10, 6, 6, 8), nrow = 2, byrow = TRUE)
x <- c(x1, x2)
for (it in 1:maxit) {
g <- grad(x)
step <- solve(H, g)
x_new <- x - step
if (sqrt(sum(step^2)) < tol) {
x <- x_new
break
}
x <- x_new
}
x_rounded <- round(x, 12)
list(par = x_rounded, value = f(x), grad = grad(x), hessian = H, iter = it)
}
